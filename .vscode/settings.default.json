{
  "rust-analyzer.cargo.targetDir": true,
  "rust-analyzer.check.extraEnv": {
    "SKIP_GUEST_BUILD": "1"
  },
  "rust-analyzer.rustfmt.extraArgs": ["+nightly"],
  "json.schemas": [
    {
      "fileMatch": ["bank.json"],
      "url": "./module-system/module-schemas/genesis-schemas/sov-bank.json"
    },
    {
      "fileMatch": ["accounts.json"],
      "url": "./module-system/module-schemas/genesis-schemas/sov-accounts.json"
    },
    {
      "fileMatch": ["value_setter.json"],
      "url": "./module-system/module-schemas/genesis-schemas/sov-value-setter.json"
    },
    {
      "fileMatch": ["prover_incentives.json"],
      "url": "./module-system/module-schemas/genesis-schemas/sov-prover-incentives.json"
    },
    {
      "fileMatch": ["sequencer_registry.json"],
      "url": "./module-system/module-schemas/genesis-schemas/sov-sequencer-registry.json"
    }
  ]
}
