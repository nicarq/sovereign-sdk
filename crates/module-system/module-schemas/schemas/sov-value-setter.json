{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CallMessage",
  "description": "This enumeration represents the available call messages for interacting with the `sov-value-setter` module.",
  "oneOf": [
    {
      "description": "Single value to set.",
      "type": "object",
      "required": [
        "set_value"
      ],
      "properties": {
        "set_value": {
          "type": "object",
          "required": [
            "value"
          ],
          "properties": {
            "gas": {
              "description": "Gas to charge. Don't charge gas if None.",
              "anyOf": [
                {
                  "$ref": "#/definitions/GasUnit(2)"
                },
                {
                  "type": "null"
                }
              ]
            },
            "value": {
              "description": "Singe new value.",
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            }
          }
        }
      },
      "additionalProperties": false
    },
    {
      "description": "Many values to set.",
      "type": "object",
      "required": [
        "set_many_values"
      ],
      "properties": {
        "set_many_values": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint8",
            "minimum": 0.0
          }
        }
      },
      "additionalProperties": false
    },
    {
      "description": "Assert the visible slot number is as expected.",
      "type": "object",
      "required": [
        "assert_visible_slot_number"
      ],
      "properties": {
        "assert_visible_slot_number": {
          "type": "object",
          "required": [
            "expected_visible_slot_number"
          ],
          "properties": {
            "expected_visible_slot_number": {
              "description": "The expected visible slot number.",
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            }
          }
        }
      },
      "additionalProperties": false
    },
    {
      "description": "Read and set many individual values.",
      "type": "object",
      "required": [
        "read_and_set_many_individual_values"
      ],
      "properties": {
        "read_and_set_many_individual_values": {
          "type": "object",
          "required": [
            "number_of_operations",
            "salt"
          ],
          "properties": {
            "number_of_operations": {
              "description": "The number of values to read and set.",
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            },
            "salt": {
              "description": "The salt.",
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            }
          }
        }
      },
      "additionalProperties": false
    },
    {
      "description": "Read and set entries in a large vector stored as a `StateValue`",
      "type": "object",
      "required": [
        "read_and_set_heavy_state"
      ],
      "properties": {
        "read_and_set_heavy_state": {
          "type": "object",
          "required": [
            "max_heavy_state_size",
            "number_of_new_values",
            "salt"
          ],
          "properties": {
            "max_heavy_state_size": {
              "description": "The max size of the heavy state.",
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            },
            "number_of_new_values": {
              "description": "The number of new values to read and set.",
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            },
            "salt": {
              "description": "The salt.",
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            }
          }
        }
      },
      "additionalProperties": false
    },
    {
      "description": "Run CPU heavy operation. Each iteration computes a hash with the Spec::Hasher.",
      "type": "object",
      "required": [
        "run_c_p_u_heavy_operation"
      ],
      "properties": {
        "run_c_p_u_heavy_operation": {
          "type": "object",
          "required": [
            "iterations"
          ],
          "properties": {
            "iterations": {
              "description": "The number of iterations.",
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            }
          }
        }
      },
      "additionalProperties": false
    },
    {
      "description": "SetValue and sleep for a while.",
      "type": "object",
      "required": [
        "set_value_and_sleep"
      ],
      "properties": {
        "set_value_and_sleep": {
          "type": "object",
          "required": [
            "sleep_millis",
            "value"
          ],
          "properties": {
            "sleep_millis": {
              "description": "The number of milliseconds to sleep.",
              "type": "integer",
              "format": "uint64",
              "minimum": 0.0
            },
            "value": {
              "description": "Singe new value.",
              "type": "integer",
              "format": "uint32",
              "minimum": 0.0
            }
          }
        }
      },
      "additionalProperties": false
    },
    {
      "description": "Trigger a panic.",
      "type": "string",
      "enum": [
        "panic"
      ]
    }
  ],
  "definitions": {
    "GasUnit(2)": {
      "description": "GasUnit is an array of size 2",
      "type": "array",
      "items": {
        "type": "number"
      },
      "maxItems": 2,
      "minItems": 2
    }
  }
}
