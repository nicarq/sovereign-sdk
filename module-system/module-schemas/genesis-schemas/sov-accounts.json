{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AccountConfig",
  "description": "Initial configuration for sov-accounts module.",
  "type": "object",
  "required": [
    "pub_keys"
  ],
  "properties": {
    "pub_keys": {
      "description": "Public keys to initialize the rollup.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/Risc0PublicKey"
      }
    }
  },
  "definitions": {
    "Risc0PublicKey": {
      "description": "The public key of an ed25519 keypair. Wraps the optimized Risc0 fork of the ed25519-dalek crate.",
      "type": "object",
      "required": [
        "pub_key"
      ],
      "properties": {
        "pub_key": {
          "type": "array",
          "items": {
            "type": "integer",
            "format": "uint8",
            "minimum": 0.0
          },
          "maxItems": 32,
          "minItems": 32
        }
      }
    }
  }
}
